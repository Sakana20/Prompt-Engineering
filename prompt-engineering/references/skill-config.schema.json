{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/prompt-engineering/skill-config.schema.json",
  "title": "Commerce Avatar Content project configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project_id": {
      "type": "string",
      "default": "",
      "description": "单个内容项目的稳定标识；用于区分互斥活动口径"
    },
    "category": {"type": "string", "minLength": 1},
    "product_name": {"type": "string", "default": ""},
    "selling_points": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    },
    "forbidden_claims": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    },
    "preset": {
      "enum": ["taobao-instant-commerce-default", "none"],
      "default": "taobao-instant-commerce-default"
    },
    "platform": {"type": "string", "default": ""},
    "campaign_name": {"type": "string", "default": ""},
    "benefit_points": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "required": {"type": "boolean", "default": true},
          "exact_match": {"type": "boolean", "default": true},
          "no_split": {"type": "boolean", "default": true},
          "priority": {"type": "integer", "minimum": 1, "default": 1}
        }
      },
      "default": []
    },
    "no_split_phrases": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": [],
      "description": "需要作为连续整体保护的项目级片段，可跨多个利益点和衔接词"
    },
    "campaign_forbidden_expressions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    },
    "required_disclosures": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    },
    "confirmed_claims": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": [],
      "description": "当前项目确认可用但不要求每条文案必写的活动事实或商品场景"
    },
    "validation_config_path": {
      "type": "string",
      "default": "",
      "description": "相对当前项目配置文件的校验配置 JSON 路径；为空时使用默认严格校验"
    },
    "language_style": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "description": "当前项目的文案语言风格；未配置字段继承默认商品导向生活化风格",
      "properties": {
        "name": {"type": "string", "minLength": 1, "default": "product-led-conversational"},
        "tone": {"type": "string", "minLength": 1},
        "point_of_view": {"type": "string", "minLength": 1},
        "sentence_style": {"type": "string", "minLength": 1},
        "emphasis": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "default": []
        },
        "avoid_phrases": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "default": []
        },
        "extra_rules": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "default": []
        }
      }
    },
    "count": {"type": "integer", "minimum": 1, "default": 1},
    "aspect_ratio": {"type": "string", "enum": ["9:16", "16:9", "1:1"], "default": "9:16"},
    "voice": {"type": "string", "default": "明朗女声"},
    "output_formats": {
      "type": "array",
      "items": {"enum": ["text", "json", "csv", "markdown", "segmentation_manuscript"]},
      "minItems": 1,
      "uniqueItems": true,
      "default": ["text"]
    },
    "output_path": {"type": ["string", "null"], "default": null},
    "output_root": {
      "type": "string",
      "default": "/Users/sakana/Desktop/Work/Codex/Prompt Engineering"
    },
    "output_date": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{8}$",
      "default": null,
      "description": "YYYYMMDD；为空时使用本地当前日期"
    },
    "task_name": {
      "type": ["string", "null"],
      "default": null,
      "description": "输出层级中的任务目录名"
    },
    "manuscript_output_directory": {
      "type": ["string", "null"],
      "default": null
    },
    "oceanengine_csv_output_path": {
      "type": ["string", "null"],
      "default": null
    },
    "oceanengine_csv_output_directory": {
      "type": ["string", "null"],
      "default": null
    },
    "batch": {"type": "boolean", "default": false},
    "debug": {"type": "boolean", "default": false},
    "plugin_directories": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    },
    "plugins": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    },
    "target_project": {
      "type": "string",
      "default": "/Users/sakana/Desktop/Work/Codex/Auto Oceanengine 26.6.22"
    },
    "preflight": {"type": "boolean", "default": true},
    "allow_import": {"type": "boolean", "default": false},
    "allow_paid_generation": {"type": "boolean", "default": false}
  },
  "required": ["category"]
}
